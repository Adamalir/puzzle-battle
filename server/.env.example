# ── Local development ──────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"
JWT_SECRET="replace-with-a-long-random-string"   # openssl rand -hex 32
PORT=3001
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"

# ── Production (Railway) ───────────────────────────────────────────────────────
# DATABASE_URL="file:./prod.db"                  # SQLite on Railway disk
# DATABASE_URL="postgresql://..."                # Railway PostgreSQL plugin URL
# JWT_SECRET="<64-char random secret>"
# PORT is set automatically by Railway — do not override
# CLIENT_URL="https://your-app.vercel.app"
# NODE_ENV="production"
